{
  "name": "ai-content-agent",
  "version": "1.0.0",
  "private": true,
  "description": "AI Content Agent - Production-ready monorepo",
  "scripts": {
    "build": "tsc -b tsconfig.build.json",
    "build:clean": "tsc -b tsconfig.build.json --clean && tsc -b tsconfig.build.json",
    "type-check": "tsc -b tsconfig.build.json --noEmit",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json}\"",
    "test": "turbo run test",
    "clean": "tsc -b tsconfig.build.json --clean && rm -rf node_modules",
    "db:generate": "cd packages/database && prisma generate",
    "db:push": "cd packages/database && prisma db push",
    "db:migrate": "cd packages/database && prisma migrate dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  }
}
