# Database
DATABASE_URL=postgresql://user:password@localhost:5432/ai_content_agent

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# S3 Storage (AWS S3, MinIO, DigitalOcean Spaces, etc.)
# For AWS S3: leave S3_ENDPOINT empty
# For MinIO: S3_ENDPOINT=http://localhost:9000
# For DigitalOcean Spaces: S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_ENDPOINT=
S3_BUCKET=ai-content-agent
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=us-east-1

# Google AI (Gemini) - REQUIRED for MVP
GOOGLE_AI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp

# OpenAI (optional)
OPENAI_API_KEY=

# Anthropic (optional)
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=

# YouTube OAuth (REQUIRED for publishing)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/oauth/youtube/callback

# Facebook OAuth (REQUIRED for publishing)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/oauth/facebook/callback

# API Server (for OAuth callbacks)
API_PORT=3000
API_HOST=0.0.0.0
API_BASE_URL=http://localhost:3000

# Workers
WORKER_CONCURRENCY=5

# Observability
LOG_LEVEL=info
OTEL_EXPORTER_OTLP_ENDPOINT=

# General
NODE_ENV=development
